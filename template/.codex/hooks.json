{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|apply_patch|functions.apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./.codex/hooks/mark-tex-edited.sh",
            "statusMessage": "LaTeX: TeX 編集を記録中..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ./.codex/hooks/build-latex-on-stop.sh",
            "statusMessage": "LaTeX: PDF ビルド中..."
          }
        ]
      }
    ]
  }
}
